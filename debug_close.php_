<?php
// debug_close.php â€” DiagnÃ³stico y test de sincronizaciÃ³n con BITGET
// Accede via: http://localhost/BITGET1/debug_close.php
// Para ejecutar un test de cierre real: aÃ±ade ?test_close=ID a la URL
header('Content-Type: text/plain; charset=utf-8');

require_once 'config.php';
require_once 'BITGET_api.php';

echo "=== DIAGNÃ“STICO DE SINCRONIZACIÃ“N BITGET ===\n";
echo "Timestamp: " . date('Y-m-d H:i:s') . "\n\n";

// ---- 1. Posiciones en BD local ----
echo "--- POSICIONES EN BD LOCAL (open) ---\n";
$stmt  = $db->query("SELECT * FROM positions WHERE status = 'open'");
$locals = $stmt->fetchAll(PDO::FETCH_ASSOC);
if (empty($locals)) {
    echo "  (ninguna posiciÃ³n abierta en BD)\n";
} else {
    foreach ($locals as $p) {
        echo "  ID#{$p['id']} | {$p['symbol']} | tipo={$p['position_type']} | qty={$p['quantity']} | entry={$p['entry_price']} | sl={$p['stop_loss']}\n";
    }
}

// ---- 2. Posiciones en BITGET ----
echo "\n--- POSICIONES EN BITGET (/fapi/v2/positionRisk) ---\n";
$real = BITGET_get_positions();
if (isset($real['code'])) {
    echo "  ERROR API: code={$real['code']} msg={$real['msg']}\n";
} elseif (empty($real)) {
    echo "  Respuesta vacÃ­a â€” posible error de conexiÃ³n o credenciales.\n";
} else {
    $found = 0;
    foreach ($real as $rp) {
        if (floatval($rp['positionAmt']) != 0) {
            echo "  ACTIVA: {$rp['symbol']} | positionAmt={$rp['positionAmt']} | entryPrice={$rp['entryPrice']} | PnL={$rp['unRealizedProfit']}\n";
            $found++;
        }
    }
    if ($found === 0) {
        echo "  (ninguna posiciÃ³n activa en BITGET â€” todas con positionAmt=0)\n";
    }
}

// ---- 3. Ã“rdenes abiertas en BITGET ----
echo "\n--- Ã“RDENES ABIERTAS EN BITGET ---\n";
foreach ($locals as $p) {
    $sym    = strtoupper($p['symbol']);
    $params = ['symbol' => $sym];
    $resp   = BITGET_request('/fapi/v1/openOrders', $params, 'GET', true);

    if (isset($resp['code'])) {
        echo "  $sym â€” ERROR: code={$resp['code']} msg={$resp['msg']}\n";
    } elseif (is_array($resp)) {
        echo "  $sym â€” " . count($resp) . " orden(es) abierta(s)\n";
        foreach ($resp as $o) {
            echo "    orderId={$o['orderId']} | type={$o['type']} | side={$o['side']} | stopPrice=" . ($o['stopPrice'] ?? 'N/A') . " | status={$o['status']}\n";
        }
    }
}
if (empty($locals)) echo "  (sin posiciones locales para comprobar)\n";

// ---- 3b. PrecisiÃ³n de precio por sÃ­mbolo ----
echo "\n--- PRECISIÃ“N DE PRECIO (tickSize) POR SÃMBOLO ---\n";
$symbols_checked = array_unique(array_column($locals, 'symbol'));
if (empty($symbols_checked)) {
    echo "  (sin posiciones locales)\n";
} else {
    foreach ($symbols_checked as $sym) {
        $precision = get_price_precision($sym);
        $current   = BITGET_get_price($sym);
        $sl_ejemplo = $current ? number_format($current * 0.988, $precision, '.', '') : 'N/A';
        echo "  $sym â€” tickSize precisiÃ³n: $precision decimales | Precio actual: $current | SL ejemplo (-1.2%): $sl_ejemplo\n";
    }
}

// ---- 4. Test de cierre real (si se solicita) ----
if (isset($_GET['test_close'])) {
    $test_id = intval($_GET['test_close']);
    echo "\n--- TEST DE CIERRE REAL para ID#$test_id ---\n";

    $stmt = $db->prepare("SELECT * FROM positions WHERE id = ? AND status = 'open'");
    $stmt->execute([$test_id]);
    $pos = $stmt->fetch(PDO::FETCH_ASSOC);

    if (!$pos) {
        echo "  ERROR: PosiciÃ³n #$test_id no encontrada o ya cerrada en BD.\n";
    } else {
        $symbol   = strtoupper($pos['symbol']);
        $type     = $pos['position_type'];
        $quantity = floatval($pos['quantity']);
        $side     = ($type === 'buy') ? 'SELL' : 'BUY';

        echo "  SÃ­mbolo: $symbol | Tipo: $type | Qty: $quantity | Cerrando con lado: $side\n";
        echo "\n  [1] Cancelando Ã³rdenes abiertas...\n";
        $cancel = BITGET_cancel_all_orders($symbol);
        echo "  Respuesta cancel: " . json_encode($cancel) . "\n";

        echo "\n  [2] Enviando orden de cierre (reduceOnly)...\n";
        $close = BITGET_close_position($symbol, $side, $quantity);
        echo "  Respuesta close: " . json_encode($close) . "\n";

        $success = BITGET_order_success($close);
        echo "\n  [3] Â¿BITGET_order_success? " . ($success ? "SÃ âœ…" : "NO âŒ") . "\n";

        if ($success) {
            echo "\n  [4] Verificando posiciÃ³n tras cierre...\n";
            usleep(500000);
            $still_open = BITGET_position_is_open($symbol);
            echo "  Â¿PosiciÃ³n sigue abierta en BITGET? " . ($still_open === true ? "SÃ (problema)" : ($still_open === false ? "NO âœ… (cerrada)" : "NULL (no se pudo verificar)")) . "\n";

            if ($still_open !== true) {
                // Actualizar BD
                $current_price = BITGET_get_price($symbol);
                $entry_price   = floatval($pos['entry_price']);
                if ($type === 'buy') {
                    $pct  = (($current_price - $entry_price) / $entry_price) * 100;
                    $fiat = ($current_price - $entry_price) * $quantity;
                } else {
                    $pct  = (($entry_price - $current_price) / $entry_price) * 100;
                    $fiat = ($entry_price - $current_price) * $quantity;
                }
                $upd = $db->prepare("UPDATE positions SET status='closed', closed_at=CURRENT_TIMESTAMP, profit_loss_percent=?, profit_loss_fiat=? WHERE id=?");
                $upd->execute([$pct, $fiat, $test_id]);
                echo "  [5] BD LOCAL ACTUALIZADA âœ… â€” PnL: " . round($pct, 2) . "% / " . round($fiat, 4) . " USDT\n";
            }
        }
    }
}

// ---- 5. Ãšltimas lÃ­neas del log de API ----
echo "\n--- ÃšLTIMAS 20 LÃNEAS DEL LOG (BITGET_api.log) ---\n";
$log_file = __DIR__ . '/BITGET_api.log';
if (file_exists($log_file)) {
    $lines = file($log_file);
    $last  = array_slice($lines, -20);
    echo implode('', $last);
} else {
    echo "  (log aÃºn no existe â€” se crearÃ¡ en la primera llamada a la API)\n";
}

echo "\n=== FIN DEL DIAGNÃ“STICO ===\n";
echo "Para test de cierre real: ?test_close=ID_DE_POSICION\n";
?>

