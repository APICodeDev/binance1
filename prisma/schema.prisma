// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Position {
  id                   Int       @id @default(autoincrement())
  symbol               String
  positionType         String    @map("position_type") // 'buy' or 'sell'
  amount               Float
  quantity             Float
  entryPrice           Float     @map("entry_price")
  stopLoss             Float     @map("stop_loss")
  status               String    @default("open") // 'open' or 'closed'
  tradingMode          String    @default("demo") @map("trading_mode") // 'demo' or 'live'
  profitLossPercent    Float?    @default(0) @map("profit_loss_percent")
  profitLossFiat       Float?    @default(0) @map("profit_loss_fiat")
  createdAt            DateTime  @default(now()) @map("created_at")
  closedAt             DateTime? @map("closed_at")
  origin               String?   // Added origin
  timeframe            String?   // Added timeframe
  commission           Float?    @default(0) // Entry commission rate (e.g., 0.0004 for 0.04%)
  pricePrecision       Int?      @default(4) @map("price_precision")
  maxProfitPercent     Float?    @default(0) @map("max_profit_percent")
  maxProfitAt          DateTime? @map("max_profit_at")

  @@map("positions")
}


model Setting {
  key   String @id
  value String

  @@map("settings")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  username     String?   @unique
  passwordHash String    @map("password_hash")
  role         String    @default("admin")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions     Session[]
  apiTokens    ApiToken[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Session {
  id         String    @id @default(cuid())
  userId     Int       @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuditLog {
  id         Int       @id @default(autoincrement())
  userId     Int?      @map("user_id")
  action     String
  targetType String?   @map("target_type")
  targetId   String?   @map("target_id")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")

  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     Int       @map("user_id")
  name       String
  tokenHash  String    @unique @map("token_hash")
  lastFour   String    @map("last_four")
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

model HeatmapPaperTrade {
  id                 Int       @id @default(autoincrement())
  symbol             String
  side               String
  amount             Float
  quantity           Float
  entryPrice         Float     @map("entry_price")
  stopPrice          Float     @map("stop_price")
  targetPrice        Float     @map("target_price")
  status             String    @default("open")
  tradingMode        String    @default("demo") @map("trading_mode")
  confidence         Float     @default(0)
  source             String    @default("Heatmap")
  timeframe          String?   @default("OrderBook")
  reasons            Json?
  exitPrice          Float?    @map("exit_price")
  exitReason         String?   @map("exit_reason")
  profitLossFiat     Float?    @default(0) @map("profit_loss_fiat")
  profitLossPercent  Float?    @default(0) @map("profit_loss_percent")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  closedAt           DateTime? @map("closed_at")

  @@map("heatmap_paper_trades")
}
